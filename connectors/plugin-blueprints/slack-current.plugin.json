{
  "plugin": {
    "id": "slack",
    "display_name": "Slack",
    "version": "0.2",
    "owner": "layer-1",
    "status": "retrofit-current"
  },
  "runtime": {
    "mode": "hybrid",
    "deployment": "cloudflare-worker",
    "health_endpoint": "/healthz"
  },
  "auth": {
    "model": "webhook-signing",
    "required_scopes": [
      "channels:history",
      "channels:read",
      "channels:join",
      "groups:history",
      "groups:read",
      "reactions:read",
      "users:read",
      "team:read"
    ],
    "workspace_pin": true
  },
  "ingest": {
    "event_sources": [
      "events-api-webhook",
      "message.channels",
      "message.groups",
      "reaction_added",
      "channel_created",
      "discover-public-channels"
    ],
    "cursor": {
      "key_pattern": "event:<iso_timestamp>:<event_id_or_entity_id>",
      "type": "timestamp",
      "supports_backfill": true
    },
    "dedupe": {
      "key_pattern": "seen:<slack_event_id>",
      "ttl_seconds": 86400
    }
  },
  "mapping": {
    "source": "slack",
    "entity_type_examples": [
      "message",
      "thread_reply",
      "reaction",
      "channel"
    ],
    "action_examples": [
      "create",
      "reply",
      "react",
      "channel_create"
    ],
    "kind_rules": [
      "structural for project-like channel creation signals",
      "moderate for substantial thread activity",
      "polish for single messages and reactions",
      "unknown for incomplete payloads"
    ],
    "tag_rules": [
      "decision when [decision] appears in message text"
    ]
  },
  "fixtures": {
    "required": [
      "slack-happy-path",
      "slack-empty-window",
      "slack-retry-dedupe",
      "slack-decision-tag",
      "slack-channel-created-structural"
    ],
    "strict_mode_required": true,
    "permissive_mode_required": true
  },
  "notes": {
    "known_gaps": [
      "private channels still require explicit invite",
      "event retrieval endpoint remains open in v0.2 and should be tightened"
    ],
    "risk_flags": [
      "Slack join and webhook rate limits",
      "scope drift during app reinstall"
    ]
  }
}
