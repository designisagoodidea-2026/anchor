{
  "plugin": {
    "id": "notion",
    "display_name": "Notion",
    "version": "0.1.0",
    "owner": "layer-1",
    "status": "candidate"
  },
  "runtime": {
    "mode": "poll",
    "deployment": "cloudflare-worker",
    "health_endpoint": "/healthz"
  },
  "auth": {
    "model": "oauth",
    "required_scopes": [
      "read_content"
    ],
    "workspace_pin": true
  },
  "ingest": {
    "event_sources": [
      "page-created",
      "page-updated",
      "database-row-created",
      "database-row-updated",
      "comment-created"
    ],
    "cursor": {
      "key_pattern": "cursor:notion:<workspace_id>:<database_or_page>",
      "type": "timestamp",
      "supports_backfill": true
    },
    "dedupe": {
      "key_pattern": "seen:notion:<entity_id>:<last_edited_time>",
      "ttl_seconds": 86400
    }
  },
  "mapping": {
    "source": "notion",
    "entity_type_examples": [
      "page",
      "database_row",
      "comment"
    ],
    "action_examples": [
      "create",
      "edit",
      "comment"
    ],
    "kind_rules": [
      "structural for major schema changes, page hierarchy refactors, ownership/decision-log reshapes",
      "moderate for substantive page updates and linked database changes",
      "polish for small text edits and light formatting",
      "unknown when content delta is unavailable"
    ],
    "tag_rules": [
      "decision when [decision] appears in title, page body extract, or comment"
    ]
  },
  "fixtures": {
    "required": [
      "notion-happy-path",
      "notion-empty-window",
      "notion-retry-dedupe",
      "notion-decision-tag",
      "notion-schema-structural"
    ],
    "strict_mode_required": true,
    "permissive_mode_required": true
  },
  "notes": {
    "known_gaps": [
      "content diff extraction quality varies by block type"
    ],
    "risk_flags": [
      "database schema diversity across workspaces"
    ]
  }
}
