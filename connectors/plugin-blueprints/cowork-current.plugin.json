{
  "plugin": {
    "id": "cowork",
    "display_name": "Cowork",
    "version": "0.1.0",
    "owner": "layer-1",
    "status": "retrofit-current"
  },
  "runtime": {
    "mode": "poll",
    "deployment": "local-watcher",
    "health_endpoint": "n/a"
  },
  "auth": {
    "model": "session",
    "required_scopes": [],
    "workspace_pin": true
  },
  "ingest": {
    "event_sources": [
      "skill-run",
      "artifact-update",
      "conversation-activity"
    ],
    "cursor": {
      "key_pattern": "cursor:cowork:<project_or_folder>",
      "type": "composite",
      "supports_backfill": false
    },
    "dedupe": {
      "key_pattern": "seen:cowork:<event_fingerprint>",
      "ttl_seconds": 86400
    }
  },
  "mapping": {
    "source": "cowork",
    "entity_type_examples": [
      "skill_run",
      "artifact",
      "conversation"
    ],
    "action_examples": [
      "run",
      "create",
      "edit",
      "comment"
    ],
    "kind_rules": [
      "structural for new skill install or major memory restructure",
      "moderate for meaningful artifact creation/updates",
      "polish for small edits and lightweight activity",
      "unknown when watcher context is insufficient"
    ],
    "tag_rules": [
      "decision when [decision] appears in filename or first line"
    ]
  },
  "fixtures": {
    "required": [
      "cowork-happy-path",
      "cowork-empty-window",
      "cowork-dedupe-retry",
      "cowork-decision-tag",
      "cowork-structural-skill-install"
    ],
    "strict_mode_required": true,
    "permissive_mode_required": true
  },
  "notes": {
    "known_gaps": [
      "no persistent checkpoint store yet; dedupe is in-memory windowed",
      "health endpoint parity differs from cloud-hosted connectors because this connector runs as local NDJSON watcher"
    ],
    "risk_flags": [
      "local process supervision required for always-on ingestion"
    ]
  }
}
